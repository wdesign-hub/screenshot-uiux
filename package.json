{
  "name": "screenshot-uiux",
  "version": "1.0.0",
  "description": "Pixel-perfect desktop and iPhone screenshots for designers",
  "main": "main.js",
  "author": "wdesign-hub",
  "license": "MIT",
  "homepage": "https://github.com/wdesign-hub/screenshot-uiux",
  "repository": {
    "type": "git",
    "url": "https://github.com/wdesign-hub/screenshot-uiux.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.wdesignhub.screenshotuiux",
    "productName": "Screenshot UIUX",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.graphics-design"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "wdesign-hub",
        "repo": "screenshot-uiux"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.9.1"
  }
}